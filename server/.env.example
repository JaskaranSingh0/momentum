## Server Environment Variables (copy to .env and fill values)

# Core
PORT=3001
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/momentum
SESSION_SECRET=change_me_dev_secret

# Google OAuth (Optional – if unset, Google auth routes return 503)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Cookie tuning for production (optional overrides)
# COOKIE_SECURE=true            # Force secure cookies (https only)
# COOKIE_SAMESITE=none          # Set to 'none' when frontend is on a different domain and HTTPS
# COOKIE_DOMAIN=                # e.g. yourcustomdomain.com (omit for default)
