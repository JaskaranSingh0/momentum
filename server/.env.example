# Server environment
PORT=3001
CLIENT_URL=http://localhost:5173
# Optionally allow multiple origins (comma-separated), e.g., preview + production URLs
# CLIENT_URLS=https://momentum-client.onrender.com,https://preview-momentum-client.onrender.com
MONGO_URI=mongodb://127.0.0.1:27017/momentum
SESSION_SECRET=change_me

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Cookie/domain
COOKIE_DOMAIN=
NODE_ENV=development
# Optional regex to allow preview subdomains (escape backslashes properly)
# CORS_ORIGIN_REGEX=^https:\/\/.*-momentum-client-.*onrender\.com$
